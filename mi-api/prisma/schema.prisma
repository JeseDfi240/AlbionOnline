generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Gold_Price {
  id        BigInt   @id @default(autoincrement())
  price     Int
  timestamp DateTime
  source    String?  @db.VarChar(50)
  createdAt DateTime @default(now())

  @@index([timestamp])
}